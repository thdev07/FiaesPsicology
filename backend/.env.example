# Google Calendar OAuth2
# Cole o conteúdo de credentials.json como string JSON em uma linha
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob"]}}
# Cole o conteúdo de token.json como string JSON em uma linha
GOOGLE_TOKEN_JSON={"access_token":"...","refresh_token":"...","token_type":"Bearer","expiry_date":0}

