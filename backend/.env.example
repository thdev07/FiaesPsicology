PORT=3001

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Resend (e-mail transacional)
RESEND_API_KEY=re_xxxxxxxxxxxx
